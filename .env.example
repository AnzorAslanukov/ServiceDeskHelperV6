# =============================================================================
# Service Desk Helper — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values.
# All variables are REQUIRED unless marked (optional).
# =============================================================================

# -----------------------------------------------------------------------------
# Athena Ticketing System API
# -----------------------------------------------------------------------------

# OAuth2 client credentials
ATHENA_CLIENT_ID=your_client_id_here
ATHENA_USERNAME=your_username_here
ATHENA_PASSWORD=your_password_here

# Base API URL
ATHENA_BASE_URL=https://your-athena-instance.example.com/athenaapi/

# OAuth2 token endpoint
ATHENA_AUTH_URL=https://your-athena-instance.example.com/athenaapi/oauth2/token

# View endpoints (POST /v1/view/workitem with type parameter)
ATHENA_INCIDENT_VIEW_URL=https://your-athena-instance.example.com/athenaapi/v1/view/workitem?type=incident
ATHENA_SERVICEREQUEST_VIEW_URL=https://your-athena-instance.example.com/athenaapi/v1/view/workitem?type=serviceRequest

# Object endpoints
ATHENA_INCIDENT_URL=https://your-athena-instance.example.com/athenaapi/v1/incident/
ATHENA_SERVICEREQUEST_URL=https://your-athena-instance.example.com/athenaapi/v1/servicerequest/
ATHENA_CHANGEREQUEST_URL=https://your-athena-instance.example.com/athenaapi/v1/changerequest/

# (optional) Change request view endpoint — defaults to empty string if not set
ATHENA_CHANGEREQUEST_VIEW_URL=https://your-athena-instance.example.com/athenaapi/v1/view/workitem?type=changeRequest

# Support group enum GUIDs (different per ticket type)
ATHENA_IR_SUPPORT_GROUP_GUID=your-ir-support-group-enum-guid
ATHENA_SR_SUPPORT_GROUP_GUID=your-sr-support-group-enum-guid

# JSON filter template for view endpoint queries
ATHENA_JSON_TEMPLATE=your-json-template-guid

# -----------------------------------------------------------------------------
# Databricks (Azure) — AI/ML Backend
# -----------------------------------------------------------------------------

# Personal Access Token for Databricks API
DATABRICKS_API_KEY=your_databricks_pat_here

# LLM serving endpoint (Claude Sonnet 4.5 via Databricks)
DATABRICKS_SONNET_4.5_URL=https://your-workspace.azuredatabricks.net/serving-endpoints/your-llm-endpoint/invocations

# Embedding serving endpoint (GTE-Large-EN, 1024 dimensions)
DATABRICKS_EMBEDDING_URL=https://your-workspace.azuredatabricks.net/serving-endpoints/your-embedding-endpoint/invocations

# SQL Warehouse connection (for vector search queries)
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id