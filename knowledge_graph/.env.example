# Databricks API Configuration (required for extraction and document sampling)
DATABRICKS_API_KEY=dapi_your_token_here
DATABRICKS_SONNET_4.5_URL=https://your-workspace.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-5/invocations
DATABRICKS_EMBEDDING_URL=https://your-workspace.azuredatabricks.net/serving-endpoints/databricks-gte-large-en/invocations
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# Neo4j Configuration (optional — only needed if using Neo4j instead of file-based store)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password